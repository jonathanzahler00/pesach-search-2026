# Resend API key — get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email address to receive feedback submissions
# Must be your verified email on the Resend free plan
FEEDBACK_TO_EMAIL=you@example.com

# Optional: separate inbox for 5787 waitlist signups (defaults to FEEDBACK_TO_EMAIL)
# WAITLIST_TO_EMAIL=you@example.com

# Set to "true" after the season to show the waitlist page and redirect /categories, /documents, etc. to home.
# Search API routes (/api/lookup, /api/feedback) stay available for next year.
# NEXT_PUBLIC_SEASON_ENDED=true

# Waitlist storage (pick one):
#
# A) Supabase (free tier) — integrated: same on-site form, rows in Table Editor, export CSV. Run scripts/supabase-waitlist.sql once.
#    Use the project URL and the service_role key (Settings → API). Server-only — do NOT use NEXT_PUBLIC_ for the key.
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
#
# B) Resend email — if Supabase vars are unset, /api/waitlist emails each signup to WAITLIST_TO_EMAIL or FEEDBACK_TO_EMAIL.
#
# C) External form — if set, the landing page links out instead of calling /api/waitlist.
# NEXT_PUBLIC_WAITLIST_FORM_URL=https://example.com/your-form
